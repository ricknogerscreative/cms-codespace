# WordPress User Uploads (tracked separately or via media server)
wp-content/uploads/
wp-content/backup-*
wp-content/cache/

# WordPress Plugins (third-party only, custom plugins should be tracked)
wp-content/plugins/
!wp-content/plugins/.gitkeep
# Exception: uncomment below if custom plugins should be tracked
# !wp-content/plugins/your-custom-plugin/

# WordPress Themes (third-party only, custom themes should be tracked)
wp-content/themes/
!wp-content/themes/.gitkeep
# Exception: keep your custom child theme tracked
# !wp-content/themes/edoa-kadence-child/

